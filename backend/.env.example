PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb+srv://<db_user>:<db_password>@cluster.mongodb.net/khamhoastore
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_HEX_SECRET_KEY
JWT_EXPIRE=30d

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Cấu hình thanh toán ngân hàng (VietQR)
BANK_ID=970422
BANK_ACCOUNT_NO=your_bank_account_number
BANK_ACCOUNT_NAME=your_bank_account_holder_name_uppercase
BANK_NAME=MB

# Cấu hình Bot thông báo Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Cấu hình gửi Email thực tế qua Gmail SMTP
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your_gmail_account@gmail.com
EMAIL_PASSWORD=your_gmail_app_password_here
EMAIL_FROM=your_gmail_account@gmail.com
